OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# --- Database (PostgreSQL via Prisma) ---
# On Vercel, Prisma Postgres auto-creates project-prefixed variables. This
# project uses lawyer_DATABASE_URL (the Prisma CLI reads it; the runtime client
# falls back to DATABASE_URL). The other two are provided by Vercel for
# reference / direct connections.
lawyer_DATABASE_URL=
lawyer_POSTGRES_URL=
lawyer_PRISMA_DATABASE_URL=

# For local development you can use DATABASE_URL instead (runtime falls back to
# it). Example: postgresql://user:password@localhost:5432/dbname?schema=public
DATABASE_URL=
